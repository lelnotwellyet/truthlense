# ============================================
# TruthLens AI Platform - .gitignore
# ============================================

# ──────────────────────────────────────────────
# Node.js
# ──────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm
.yarn/cache
.yarn/unplugged
.yarn/install-state.gz
.pnp.*
package-lock.json.bak

# ──────────────────────────────────────────────
# Python
# ──────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.venv/
venv/
env/
*.egg-info/
*.egg
dist/
build/
*.whl
.Python
pip-log.txt
pip-delete-this-directory.txt

# ──────────────────────────────────────────────
# Environment Variables
# ──────────────────────────────────────────────
# .env files are tracked so collaborators can clone and run directly
# ⚠️  Do NOT make this repo public with real API keys!
# .env
# .env.local
# .env.*.local
# NOTE: .env.example files ARE tracked (templates for setup)

# ──────────────────────────────────────────────
# Build Outputs
# ──────────────────────────────────────────────
dist/
build/
.next/
out/
*.tsbuildinfo

# ──────────────────────────────────────────────
# IDE & Editors
# ──────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
*.sublime-project
*.sublime-workspace
.project
.classpath
.settings/

# ──────────────────────────────────────────────
# OS Generated Files
# ──────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
Thumbs.db
ehthumbs.db
Desktop.ini

# ──────────────────────────────────────────────
# Machine Learning Models & Artifacts
# ──────────────────────────────────────────────
*.pkl
*.h5
*.pt
*.pth
*.onnx
models/*.bin
*.hdf5
*.joblib
*.safetensors

# ──────────────────────────────────────────────
# Testing & Coverage
# ──────────────────────────────────────────────
coverage/
.nyc_output/
htmlcov/
.pytest_cache/
.coverage
.coverage.*
*.cover
*.lcov

# ──────────────────────────────────────────────
# Miscellaneous
# ──────────────────────────────────────────────
*.log
.cache/
tmp/
.temp/
.parcel-cache/
