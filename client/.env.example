# ============================================
# TruthLens Client (Vite + React) - Environment Variables
# ============================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# All client-side env vars MUST be prefixed with VITE_
# to be exposed to the browser bundle.

# ──────────────────────────────────────────────
# Supabase Configuration
# ──────────────────────────────────────────────
# Your Supabase project URL (e.g., https://xxxxx.supabase.co)
# VITE_SUPABASE_URL=

# Public anon key — safe for client-side use (RLS enforced)
# VITE_SUPABASE_ANON_KEY=

# ──────────────────────────────────────────────
# API Configuration
# ──────────────────────────────────────────────
# Base URL of the truthlens API server
VITE_API_URL=http://localhost:5000/api

# ──────────────────────────────────────────────
# Application Metadata
# ──────────────────────────────────────────────
# Display name used in the UI
VITE_APP_NAME=truthlens

# Current application version
VITE_APP_VERSION=1.0.0
