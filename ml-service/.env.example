# ============================================
# TruthLens ML Service (FastAPI) - Environment Variables
# ============================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ──────────────────────────────────────────────
# Server Configuration
# ──────────────────────────────────────────────
# Host to bind the Uvicorn server to
HOST=0.0.0.0

# Port the FastAPI server listens on
PORT=8000

# Enable debug mode (auto-reload, verbose errors)
# Set to false in production
DEBUG=true

# ──────────────────────────────────────────────
# Model Paths
# ──────────────────────────────────────────────
# Path to the trained fake news classification model
MODEL_PATH=models/fake_news_model.pkl

# Path to the fitted TF-IDF vectorizer
VECTORIZER_PATH=models/tfidf_vectorizer.pkl

# ──────────────────────────────────────────────
# External API Keys
# ──────────────────────────────────────────────
# Google Fact Check Tools API key (https://developers.google.com/fact-check/tools/api)
GOOGLE_FACT_CHECK_API_KEY=

# ──────────────────────────────────────────────
# OCR Configuration
# ──────────────────────────────────────────────
# Path to Tesseract OCR binary (uncomment & set if not in PATH)
# Linux:   /usr/bin/tesseract
# macOS:   /usr/local/bin/tesseract
# Windows: C:\Program Files\Tesseract-OCR\tesseract.exe
# TESSERACT_CMD=/usr/bin/tesseract

# ──────────────────────────────────────────────
# CORS Configuration
# ──────────────────────────────────────────────
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:5000,http://localhost:5173

# ──────────────────────────────────────────────
# Logging
# ──────────────────────────────────────────────
# Log level: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO
